# Renomeie pra .env.local e preencha (todos opcionais — sem as chaves, o app roda em modo MOCK determinístico)

# Supabase
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# PlantNet (cadastre em https://my.plantnet.org/ → "API key")
VITE_PLANTNET_API_KEY=

# Gemini Vision (segunda opinião — botão "Usar IA")
# Pegue em https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
